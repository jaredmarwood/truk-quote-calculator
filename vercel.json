{
  "buildCommand": "yarn build",
  "outputDirectory": "dist/client",
  "devCommand": "yarn dev",
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/blog/stale-fuel-data-losses", "dest": "/blog/stale-fuel-data-losses.html" },
    { "src": "/recruit", "dest": "/recruit.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
