{
  "name": "truk-2",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"server,web\" --prefix-colors \"green,magenta\" --kill-others-on-fail \"yarn dev:server\" \"yarn dev:web\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3001",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
